# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# Google AI Studio — free tier (aistudio.google.com)
# Primary key (first in rotation)
GOOGLE_API_KEY=<your-key-here>

# All Gemini keys (comma-separated, used in rotation with fallback)
GEMINI_API_KEYS=<your-key-here>

# OpenAI — platform.openai.com
OPENAI_API_KEY=<your-key-here>

# HuggingFace — write token for dataset upload (hf.co/settings/tokens)
HF_TOKEN=<your-key-here>

# Optional
TOGETHER_API_KEY=<your-key-here>
ANTHROPIC_API_KEY=<your-key-here>
